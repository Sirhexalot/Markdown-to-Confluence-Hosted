{
  "name": "confluence-markdown-bridge",
  "displayName": "Confluence Markdown Bridge",
  "description": "Write Confluence pages in Markdown, convert Markdown to Confluence Wiki markup, and turn Confluence DOC exports back into Markdown.",
  "version": "0.0.9",
  "publisher": "Sirhexalot",
  "license": "SEE LICENSE IN LICENSE.txt",
  "icon": "images/icon.png",
  "homepage": "https://github.com/Sirhexalot/Confluence-Markdown-Bridge",
  "bugs": {
    "url": "https://github.com/Sirhexalot/Confluence-Markdown-Bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sirhexalot/Confluence-Markdown-Bridge.git"
  },
  "galleryBanner": {
    "color": "#123a63",
    "theme": "dark"
  },
  "files": [
    "dist/**",
    "images/**",
    "README.md",
    "LICENSE.txt",
    "package.json"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "confluence",
    "markdown",
    "wiki",
    "on-prem",
    "import",
    "export",
    "doc",
    "documentation"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md2doc.convertCurrentFile",
        "title": "Markdown to DOC: Convert Current File"
      },
      {
        "command": "md2doc.convertFile",
        "title": "Markdown to DOC: Convert File"
      },
      {
        "command": "md2doc.convertMarkdownToWikiFile",
        "title": "Markdown to Confluence Wiki: Convert File"
      },
      {
        "command": "md2doc.convertMarkdownToWikiClipboard",
        "title": "Markdown to Confluence Wiki: Copy to Clipboard"
      },
      {
        "command": "md2doc.convertWordCurrentFile",
        "title": "Confluence DOC to Markdown: Convert Current File"
      },
      {
        "command": "md2doc.convertWordFile",
        "title": "Confluence DOC to Markdown: Convert File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "md2doc.convertMarkdownToWikiFile",
          "when": "resourceExtname == .md",
          "group": "navigation"
        },
        {
          "command": "md2doc.convertMarkdownToWikiClipboard",
          "when": "resourceExtname == .md",
          "group": "navigation"
        },
        {
          "command": "md2doc.convertWordFile",
          "when": "resourceExtname == .doc || resourceExtname == .docx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "lint:md": "node scripts/lint-markdown.mjs",
    "package": "vsce package --allow-missing-repository",
    "test:md2doc": "pnpm build && node dist/cli.js md2doc",
    "test:doc2md": "pnpm build && node dist/cli.js doc2md",
    "test:md2wiki": "pnpm build && node dist/cli.js md2wiki"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.1",
    "markdownlint": "^0.41.0",
    "typescript": "^5.7.2"
  }
}
